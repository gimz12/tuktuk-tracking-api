NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/tuktuk_tracking?retryWrites=true&w=majority

JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=8h
JWT_DEVICE_SECRET=change-me-device-jwt-secret
JWT_DEVICE_EXPIRES_IN=30d

BOOTSTRAP_ADMIN_EMAIL=admin@police.gov.lk
BOOTSTRAP_ADMIN_PASSWORD=

THROTTLE_TTL=60
THROTTLE_LIMIT=120
